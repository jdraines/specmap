# Specmap API server configuration

# Database
DATABASE_URL=postgres://specmap:specmap_dev@localhost:5432/specmap?sslmode=disable

# Server
PORT=8080
BASE_URL=https://localhost:8080

# GitHub OAuth App (register at https://github.com/settings/applications/new)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Session secret (32+ random bytes, hex-encoded). Generate with: openssl rand -hex 32
SESSION_SECRET=

# Token encryption key (32 bytes, hex-encoded). Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# CORS origin for frontend dev server
CORS_ORIGIN=http://localhost:5173

# TLS certificates for local dev (generate with: mkcert localhost 127.0.0.1 ::1)
TLS_CERT=localhost+1.pem
TLS_KEY=localhost+1-key.pem
