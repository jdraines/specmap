# Specmap API server configuration

# Server
PORT=8080
BASE_URL=http://localhost:8080

# Database (SQLite)
DATABASE_PATH=./specmap.db

# --- Auth (at least one method required per provider) ---

# PAT mode: forge token (falls back to `gh auth token` / `glab config get token`)
GITHUB_TOKEN=
GITLAB_TOKEN=

# OAuth mode (optional — for enterprise environments that restrict PATs)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=

# --- Forge detection (optional — auto-detected from git remote) ---
# SPECMAP_FORGE=github|gitlab
# SPECMAP_FORGE_URL=https://gitlab.example.com   # for self-hosted GitLab

# --- Server secrets (optional — auto-generated if not set) ---
# SESSION_SECRET=     # 32+ random chars. Generate with: openssl rand -hex 32
# ENCRYPTION_KEY=     # 32 bytes hex-encoded. Generate with: openssl rand -hex 32

# --- LLM (optional — enables walkthrough generation) ---
# SPECMAP_MODEL=gpt-4o-mini        # LLM model for walkthrough generation
# SPECMAP_API_KEY=                  # API key (same BYOK config as MCP tool)
# SPECMAP_API_BASE=                 # Custom API base URL (optional)

# CORS origin for frontend dev server
CORS_ORIGIN=http://localhost:5173
