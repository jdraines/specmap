# Specmap API server configuration

# Server
PORT=8080
BASE_URL=http://localhost:8080

# Database (SQLite)
DATABASE_PATH=./specmap.db

# GitHub OAuth App (register at https://github.com/settings/developers)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Session secret (32+ random chars). Generate with: openssl rand -hex 32
SESSION_SECRET=

# Token encryption key (32 bytes, hex-encoded). Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# CORS origin for frontend dev server
CORS_ORIGIN=http://localhost:5173
